Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Exact Total Radiated Power: \"\>", "\[InvisibleSpace]", 
   RowBox[{
    FractionBox["1", "32"], " ", "eta", " ", 
    SuperscriptBox["I0", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"4", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"-", 
         FractionBox[
          RowBox[{"2", " ", 
           SuperscriptBox["\[Pi]", "2"], " ", 
           SuperscriptBox["w", "2"]}], 
          SuperscriptBox["lambda", "2"]]}]]}], "+", 
      FractionBox[
       RowBox[{
        SqrtBox[
         FractionBox["2", "\[Pi]"]], " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", 
           SuperscriptBox["lambda", "2"]}], "+", 
          RowBox[{"4", " ", 
           SuperscriptBox["\[Pi]", "2"], " ", 
           SuperscriptBox["w", "2"]}]}], ")"}], " ", 
        RowBox[{"Erf", "[", 
         FractionBox[
          RowBox[{
           SqrtBox["2"], " ", "\[Pi]", " ", "w"}], "lambda"], "]"}]}], 
       RowBox[{"lambda", " ", "w"}]]}], ")"}]}]}],
  SequenceForm[
  "Exact Total Radiated Power: ", 
   Rational[1, 32] $CellContext`eta $CellContext`I0^2 (
    4 E^((-2) $CellContext`lambda^(-2) 
       Pi^2 $CellContext`w^2) + $CellContext`lambda^(-1) (2/Pi)^
      Rational[1, 2] $CellContext`w^(-1) (-$CellContext`lambda^2 + 
      4 Pi^2 $CellContext`w^2) 
     Erf[2^Rational[1, 2] $CellContext`lambda^(-1) Pi $CellContext`w])],
  Editable->False]], "Print",
